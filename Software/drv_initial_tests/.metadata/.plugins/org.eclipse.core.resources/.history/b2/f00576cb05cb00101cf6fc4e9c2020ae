void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim)
{
    if (htim == &htim6) {
        // advance phases
        phaseA += speed_increment;
        phaseB += speed_increment;
        phaseC += speed_increment;

        // Wrap around in both directions
        if (phaseA >= SINE_TABLE_SIZE) phaseA -= SINE_TABLE_SIZE;
        else if (phaseA < 0.0f)        phaseA += SINE_TABLE_SIZE;

        if (phaseB >= SINE_TABLE_SIZE) phaseB -= SINE_TABLE_SIZE;
        else if (phaseB < 0.0f)        phaseB += SINE_TABLE_SIZE;

        if (phaseC >= SINE_TABLE_SIZE) phaseC -= SINE_TABLE_SIZE;
        else if (phaseC < 0.0f)        phaseC += SINE_TABLE_SIZE;

        uint16_t dutyA = (uint16_t)(
            (sine_table[(uint16_t)phaseA] * voltage_amplitude) /
            TIM1_FULL_DUTY
        );
        uint16_t dutyB = (uint16_t)(
            (sine_table[(uint16_t)phaseB] * voltage_amplitude) /
            TIM1_FULL_DUTY
        );
        uint16_t dutyC = (uint16_t)(
            (sine_table[(uint16_t)phaseC] * voltage_amplitude) /
            TIM1_FULL_DUTY
        );

        __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, dutyA);
        __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_2, dutyB);
        __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, dutyC);
    }

    if (htim == &htim7) {
        TLE_Encoder_CalcSpeed(&encoder);
        SpeedLoop_Update();
        if (++pos_loop_divider >= 2) {
            pos_loop_divider = 0;
