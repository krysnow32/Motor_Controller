/* ====================  SETINGS for DRV8323  ==================== */
void DRV8323_Init(void)
{

    // 0. Disable nFAULT EXTI interrupt during DRV startup
    HAL_NVIC_DisableIRQ(EXTI9_5_IRQn);
    __HAL_GPIO_EXTI_CLEAR_FLAG(M_nFault_Pin); // clear any pending edge
    HAL_GPIO_WritePin(M_HIZ_GPIO_Port, M_HIZ_Pin, GPIO_PIN_RESET);
    HAL_GPIO_WritePin(M_EN_GPIO_Port, M_EN_Pin, GPIO_PIN_SET);
    HAL_Delay(10);
    HAL_GPIO_WritePin(DRV_CS_GPIO_Port, DRV_CS_Pin, GPIO_PIN_SET);

    HAL_Delay(10);

	// 4. Settings
    drv8323_reg_write(DRV8323_REG_GATE_DRIVE_HS, 0x0FC);  // HS IDRIVE 1000/1140 mA
    drv8323_reg_write(DRV8323_REG_GATE_DRIVE_LS, 0x3FC);  // LS IDRIVE 1000/1140 mA, 2 µs tdrive
    drv8323_reg_write(DRV8323_REG_OCP_CONTROL,   0x359);  // Deadtime 400 ns, auto‑retry, 4 µs deglitch
    drv8323_reg_write(DRV8323_REG_CSA_CONTROL,   0x283);  // 20 V/V gain, bidirectional
    drv8323_reg_write(DRV8323_REG_DRIVER_CONTROL,0x0A0);  // 3× PWM, protections active

       __HAL_GPIO_EXTI_CLEAR_FLAG(M_nFault_Pin);
       HAL_NVIC_EnableIRQ(EXTI9_5_IRQn);
}

/* ==================== SINE TABLE ==================== */
void Generate_Sine_Table(void)
{
    for (uint16_t i = 0; i < SINE_TABLE_SIZE; i++)
    {
        float angle=(2.0f * M_PI * i) / SINE_TABLE_SIZE;
        float sin_norm=(sinf(angle) + 1.0f) * 0.5f;
        sine_table[i]=(uint16_t)(sin_norm * TIM1_FULL_DUTY);
    }
}

/* ==================== ALIGNMENT ===================== */
void Motor_Align(void)
{

	HAL_TIM_Base_Stop_IT(&htim6); // stop timer interrupt
    voltage_amplitude=TIM1_FULL_DUTY/10;
    //Energise one phase to align rotor
    __HAL_TIM_SET_COMPARE(&htim1,TIM_CHANNEL_1,voltage_amplitude);
    __HAL_TIM_SET_COMPARE(&htim1,TIM_CHANNEL_2,0);
    __HAL_TIM_SET_COMPARE(&htim1,TIM_CHANNEL_3,0);

    HAL_Delay(300); // wait for rotor to align

    __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, 0);

    phaseA = 0.0f;
    phaseB = SINE_TABLE_SIZE / 3.0f;
    phaseC = 2.0f * SINE_TABLE_SIZE / 3.0f;
    // Also safe to reset speed command at start
    intermediate_rpm = 0.0f;
    speed_increment  = 0.0f;

    // Re-enable PWM updates
    HAL_TIM_Base_Start_IT(&htim6);

}
static void ResetControllersForNewMove(void)
{
    // Position PI
    pos_err_int = 0.0f;

    // Speed PI
    speed_err_int = 0.0f;

    // Speed / ramp state
    rpm_filtered     = 0.0f;
    intermediate_rpm = 0.0f;
    speed_increment  = 0.0f;

    // Make sure speed command starts from zero
    target_rpm = 0.0f;
}
// ==================== SPEED CALCULATION =====================
#define NUM_SAMPLES 5
uint8_t divider = 10;
int8_t coefficients[5] = {2, 1, 0, -1, -2};
float y[NUM_SAMPLES] = {0};  // newest → oldest
uint8_t sample_count = 0;
float dt = 0.005f;
float speed = 0.0f;
static float last_angle = 0.0f;
static float angle_unwrapped = 0.0f;

// Called every 5 ms (200 Hz)
void TLE_Encoder_CalcSpeed(TLE_Encoder_t *enc)
{
    // Read current angle
    float angle = TLE_Encoder_ReadAngle(enc);
    float delta = angle - last_angle;

        if (delta > 180.0f) {
            // wrapped backward (e.g. 359 → 1)
            angle_unwrapped -= (360.0f - delta);
        } else if (delta < -180.0f) {
            // wrapped forward (e.g. 1 → 359)
            angle_unwrapped += (360.0f + delta);
        } else {
            angle_unwrapped += delta;
        }
        // Update last angle
        last_angle = angle;

    // Shift older samples down
    for (int i = NUM_SAMPLES - 1; i > 0; i--) {
        y[i] = y[i - 1];
    }

    // Store newest sample at index 0
    y[0] = angle_unwrapped;
    if (sample_count < NUM_SAMPLES)
    {
        sample_count++;
    }
    if (sample_count >= NUM_SAMPLES)
        {
    	float result = 0.0f;
        for (int i = 0; i < NUM_SAMPLES; i++)
        {
            result += coefficients[i] * y[i];
        }
        speed = result / (dt * divider);
    		enc->data.rpm = speed/6.0f; // convert deg/s to RPM
    		enc->data.angle_multi_deg = angle_unwrapped; //probably no need for so many decimal places it makes computation slower
        }
}

void SpeedLoop_Update(void)
{
    if (!motor_running || drv_fault_active) {
        intermediate_rpm = 0.0f;
        speed_increment  = 0.0f;
        speed_err_int    = 0.0f;
        return;
    }

    float rpm_meas_raw = TLE_Encoder_GetSpeed(&encoder);
    // Low-pass filter
    rpm_filtered += SPEED_FILTER_ALPHA * (rpm_meas_raw - rpm_filtered);
    // Use rpm_filtered for the controller
    float rpm_meas = rpm_filtered;
    float err      = target_rpm - rpm_meas;

    // Proportional term only (no I yet)
    float p_term = SPEED_KP * err;

    // First build unsaturated command using current integrator
    float rpm_cmd_unsat = target_rpm + p_term + SPEED_KI * speed_err_int;

    // Compute the effective upper limit (speed limit AND increment limit)
    float rpm_limit_by_inc =
        (SPEED_INCREMENT_MAX * 60.0f * TIM6_UPDATE_FREQ) /
        (MOTOR_POLE_PAIRS * SINE_TABLE_SIZE);

    float upper_limit = RPM_CMD_MAX;
    if (rpm_limit_by_inc < upper_limit) {
        upper_limit = rpm_limit_by_inc;
    }

    // Apply saturation
    float rpm_cmd = rpm_cmd_unsat;
    if (rpm_cmd > upper_limit) rpm_cmd = upper_limit;
    if (rpm_cmd < RPM_CMD_MIN) rpm_cmd = RPM_CMD_MIN;

    // Anti-windup: only integrate if we are NOT saturating in the same
    // direction as the error
    bool sat_high = (rpm_cmd >= upper_limit - 1e-3f);
    bool sat_low  = (rpm_cmd <= RPM_CMD_MIN + 1e-3f);

    // Integrate only when close to target and not pushing into a limit
    if (fabsf(err) < SPEED_I_BAND_RPM &&
        !((sat_high && err > 0.0f) || (sat_low && err < 0.0f)))
    {
        speed_err_int += err * dt;
    }
    else if (fabsf(err) > 2.0f * SPEED_I_BAND_RPM)
    {
        // Optional: reset integrator when far away to avoid old windup
        speed_err_int = 0.0f;
    }
/*
    intermediate_rpm = rpm_cmd;

    // Convert commanded mechanical RPM to electrical phase increment
    speed_increment =
        (intermediate_rpm * MOTOR_POLE_PAIRS * SINE_TABLE_SIZE) /
        (60.0f * TIM6_UPDATE_FREQ);
        */
    // Rate limiting: limit how fast intermediate_rpm can change
    float max_step_up   = ACCEL_LIMIT_RPM_PER_SEC * dt;       // speed up
       float max_step_down = DECCEL_LIMIT_RPM_PER_SEC * dt; // 4x faster slow down

       float drpm = rpm_cmd - intermediate_rpm;

       if (drpm > 0.0f) {
           // accelerating
           if (drpm > max_step_up) {
               drpm = max_step_up;
           }
       } else {
           // decelerating (drpm <= 0)
           if (drpm < -max_step_down) {
               drpm = -max_step_down;
           }
       }

       intermediate_rpm += drpm;

       // Convert commanded mechanical RPM to electrical phase increment
       speed_increment =
           (intermediate_rpm * MOTOR_POLE_PAIRS * SINE_TABLE_SIZE) /
           (60.0f * TIM6_UPDATE_FREQ);
}
void PositionLoop_Update(float dt_loop)
{
    if (!motor_running || drv_fault_active) {
        pos_err_int = 0.0f;
        return;
    }

    // Motor angle (multi-turn) in degrees
    float motor_angle_deg = TLE_Encoder_GetAngleMultiDeg(&encoder);

    // Output shaft angle
    float pos_out_deg = motor_angle_deg / GEAR_RATIO;

    float pos_err_deg = target_pos_out_deg - pos_out_deg;

    // Deadband
    if (fabsf(pos_err_deg) < POS_DEADBAND_DEG) {
        // If we're very close AND already almost stopped, then treat as "at rest"
        if (fabsf(rpm_filtered) < 1.0f) {  // tune this threshold
            pos_err_int   = 0.0f;
            target_rpm    = 0.0f;

            speed_err_int    = 0.0f;
            intermediate_rpm = 0.0f;
            speed_increment  = 0.0f;
            rpm_filtered     = 0.0f;
        } else {
            // Close to target but still moving: don't drive I, but let speed loop brake
            pos_err_int = 0.0f;
            target_rpm  = 0.0f;
        }
        return;
    }
    // Compute proportional term
    float p_term = POS_KP * pos_err_deg;

    // Compute tentative integrator update
    float pos_err_int_new = pos_err_int + pos_err_deg * dt_loop;

    // Optional: limit integrator magnitude (prevents huge values)
    const float POS_I_MAX = 200.0f;  // tune as needed (rpm/ Ki)
    if (pos_err_int_new > POS_I_MAX)  pos_err_int_new = POS_I_MAX;
    if (pos_err_int_new < -POS_I_MAX) pos_err_int_new = -POS_I_MAX;

    // Unsaturated PI output
    float cmd_rpm_unsat = p_term + POS_KI * pos_err_int_new;

    // Saturate
    float cmd_rpm = cmd_rpm_unsat;
    if (cmd_rpm > MAX_RPM)  cmd_rpm = MAX_RPM;
    if (cmd_rpm < MIN_RPM)  cmd_rpm = MIN_RPM;

    // Anti-windup:
    // Only accept the new integrator if we are NOT saturating "into" the limit
    bool sat_high = (cmd_rpm >= MAX_RPM - 1e-3f);
    bool sat_low  = (cmd_rpm <= MIN_RPM + 1e-3f);

    if (!((sat_high && pos_err_deg > 0.0f) || (sat_low && pos_err_deg < 0.0f)))
    {
        // Safe to apply new integrator value
        pos_err_int = pos_err_int_new;
    }
    // else: discard this step's integrator update → no further windup

    target_rpm = cmd_rpm;
}

void Update_VoltageAmplitude(void)
{
    if (!motor_running || drv_fault_active) {
        voltage_amplitude = 0;
        return;
    }

    // Use the commanded (ramped) speed for V/f
    float rpm_for_vf = fabsf(intermediate_rpm);

    if (rpm_for_vf <= 0.5f) {
        // Near zero: no voltage
        voltage_amplitude = 0;
        return;
    }

    // Ideal duty from Kv and bus voltage: rpm / (Kv * Vdc)
    float duty = rpm_for_vf / (MOTOR_KV_RPM_PER_V * SUPPLY_VOLTAGE);

    // Small gain to compensate losses
    duty *= 1.3f;

    // Clamp to safe range when running
    if (duty < VF_MIN_AMPLITUDE)
        duty = VF_MIN_AMPLITUDE;
    if (duty > VF_MAX_AMPLITUDE)
        duty = VF_MAX_AMPLITUDE;

    voltage_amplitude = (uint16_t)(duty * TIM1_FULL_DUTY);
}
#define LINE_MAX_LENGTH 4
static char line_buffer[LINE_MAX_LENGTH + 1];
static uint32_t line_length;
static bool display_active = false;



void line_append(uint8_t value)
{
    if (value == '\r' || value == '\n') {
        if (line_length > 0) {
            line_buffer[line_length] = '\0';

            float val = atof(line_buffer);
            target_pos_out_deg += val;

            // fresh start for this move
            ResetControllersForNewMove();

            if (!motor_running && !drv_fault_active) {
                HAL_GPIO_WritePin(
                    M_HIZ_GPIO_Port,
                    M_HIZ_Pin,
                    GPIO_PIN_SET
                );
                Motor_Align();
                motor_running = true;
                ResetControllersForNewMove();
            }

            display_active = true;

            printf(
                "UART cmd: \"%s\" -> target_pos_out_deg = %.2f\r\n",
                line_buffer,
                target_pos_out_deg
            );

            line_length = 0;
        }
    } else {
        if (line_length >= LINE_MAX_LENGTH) {
            line_length = 0;
        }
        line_buffer[line_length++] = (char)value;
    }
}
/* ==================== FAULT SERVICE ===================== */
void DRV8323_ServiceFault(void)
{
    if (drv_fault_active == false) return;       // nothing to do

    //zeroing variables
    motor_running = false;
    intermediate_rpm = 0;
    target_rpm = 0;
    voltage_amplitude = 0;
    __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, 0);
    __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_2, 0);
    __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_3, 0);


    //Read fault registers for debugging/log
    //drv_fault_reg1 = drv8323_reg_read(DRV8323_REG_FAULT_STATUS_1);
    //drv_fault_reg2 = drv8323_reg_read(DRV8323_REG_VGS_STATUS_2);

    // Blink quick feedback
    for(int i = 0; i < 10; i++) {
        HAL_GPIO_TogglePin(LINK_GPIO_Port, LINK_Pin);
        HAL_Delay(50);
    }
    static uint8_t clear_counter = 0;
    if (HAL_GPIO_ReadPin(M_nFault_GPIO_Port, M_nFault_Pin) == GPIO_PIN_SET)
    {
    	if (++clear_counter > 3)
        { // Confirm fault line stable for a few cycles
            drv_fault_active = false;
            drv8323_reg_write(DRV8323_REG_DRIVER_CONTROL, 0x0A1);
            clear_counter = 0;
        }
    }
    else
    {
        clear_counter = 0;
    }

}
uint32_t last_press_tick = 0;

void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin)
{
	if(GPIO_Pin == M_nFault_Pin)
	{
        // Fast reaction to fault: disable MOSFETs instantly
        HAL_GPIO_WritePin(M_HIZ_GPIO_Port, M_HIZ_Pin, GPIO_PIN_RESET);
        drv_fault_active = true;
        return;
	}
	/* ==================== BUTTON ======================= */
    if (GPIO_Pin == BTN_A_Pin)
    {

        uint32_t now = HAL_GetTick();
        if (now - last_press_tick < 200) return; // ignore if within 200ms of last press
        last_press_tick = now;

        HAL_GPIO_TogglePin(FAULT_GPIO_Port, FAULT_Pin);

        if (!motor_running && !drv_fault_active)
        {
        	HAL_GPIO_WritePin(M_HIZ_GPIO_Port, M_HIZ_Pin, GPIO_PIN_SET); // Enable mosfets
            Motor_Align();
            motor_running = true;
            //float motor_angle = TLE_Encoder_GetAngleMultiDeg(&encoder);
            target_pos_out_deg = 0.0f;                        // define current as 0°
            target_rpm         = 0.0f;
            speed_err_int      = 0.0f;
            pos_err_int        = 0.0f;
        }
        else
        {
        	target_pos_out_deg += 45.0f;
        	ResetControllersForNewMove();

        }
    }
