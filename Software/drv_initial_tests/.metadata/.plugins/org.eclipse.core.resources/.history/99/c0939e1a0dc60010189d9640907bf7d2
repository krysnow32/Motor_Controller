// Write register
// ============================================================================
// Frame format: [15]=RW | [14:11]=Address | [10:0]=Data
// ============================================================================
void drv8323_reg_write(uint8_t reg, uint16_t value) {
    uint16_t frame = DRV8323_RW_WRITE | ((reg & 0x0F) << 11) | (value & 0x07FF);

    HAL_GPIO_WritePin(DRV_CS_GPIO_Port, DRV_CS_Pin, GPIO_PIN_RESET); // CS low
    HAL_SPI_Transmit(&hspi1, (uint8_t *)&frame, 1, HAL_MAX_DELAY);
    HAL_GPIO_WritePin(DRV_CS_GPIO_Port, DRV_CS_Pin, GPIO_PIN_SET);   // CS high
    HAL_Delay(1); // Small delay to ensure proper timing
}


