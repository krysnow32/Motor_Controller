//--DRV8323 register definitions------------------------------------------------
// Read-only status registers
#define DRV8323_REG_FAULT_STATUS_1    0x00  // Fault Status Register 1
#define DRV8323_REG_VGS_STATUS_2      0x01  // VGS Fault Status Register 2
// Control and configuration registers
#define DRV8323_REG_DRIVER_CONTROL    0x02  // Driver Control Register
#define DRV8323_REG_GATE_DRIVE_HS     0x03  // High Side Gate Drive Control
#define DRV8323_REG_GATE_DRIVE_LS     0x04  // Low Side Gate Drive Control
#define DRV8323_REG_OCP_CONTROL       0x05  // Over Current Protection Control
#define DRV8323_REG_CSA_CONTROL       0x06  // Current Sense Amplifier Control

#define DRV8323_RW_WRITE  0x0000       // bit15 = 0 → write
#define DRV8323_RW_READ   0x8000       // bit15 = 1 → read
//------------------------------------------------------------------------------
// Motor control definitions
#define SINE_TABLE_SIZE     256
uint16_t sine_table[SINE_TABLE_SIZE];
#define TIM1_FULL_DUTY      1599
#define TIM6_UPDATE_FREQ    40000
#define MOTOR_POLE_PAIRS    20
#define MAX_RPM             300.0f
#define RPM_STEP            100.0f
/* Motion variables */
volatile float desired_rpm = 0.0f;
volatile float target_rpm  = 0.0f;
volatile bool  motor_running = false;
float speed_increment = 0.0f;
uint16_t voltage_amplitude = 0;
/* Phase accumulators */
volatile float phaseA=0.f, phaseB=SINE_TABLE_SIZE/3.f, phaseC=SINE_TABLE_SIZE/3.f*2.f;
/* DRV fault flag */
volatile bool drv_fault_active = false;   // Interrupt flag: nFAULT went low
volatile uint16_t drv_fault_reg1 = 0;
volatile uint16_t drv_fault_reg2 = 0;
